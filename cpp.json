{
	"CP Fast Template": {
		"prefix": "cp",
		"body": [
			"#include <bits/stdc++.h>",
			"using namespace std;",
			"",
			"#define f ios::sync_with_stdio(false); cin.tie(NULL); cout.tie(NULL);",
			"",
			"#define ll long long",
			"#define ld long double",
			"",
			"#define pb push_back",
			"#define eb emplace_back",
			"#define all(x) x.begin(), x.end()",
			"#define rall(x) x.rbegin(), x.rend()",
			"",
			"#define F first",
			"#define S second",
			"",
			"const int M = 1e9+7;",
			"const int N = 2e5+5;",
			"",
			"using vi = vector<int>;",
			"using vll = vector<long long>;",
			"using pii = pair<int,int>;",
			"using pll = pair<long long,long long>;",
			"",
			"void solve(){",
			"    $1",
			"}",
			"",
			"int main(){",
			"    f",
			"",
			"    int t = 1;",
			"    cin >> t;",
			"",
			"    while(t--){",
			"        solve();",
			"    }",
			"}"
		],
		"description": "Fast competitive programming template"
	},
	"For Loop": {
		"prefix": "fr",
		"body": [
			"for(int $1 = $2; $1 < $3; $1++){",
			"    $4",
			"}"
		]
	},
	"Reverse For": {
		"prefix": "rf",
		"body": [
			"for(int $1 = $2; $1 >= $3; $1--){",
			"    $4",
			"}"
		]
	},
	"Vector": {
		"prefix": "v",
		"body": [
			"vector<$1> $2($3);"
		]
	},
	"Vector Input": {
		"prefix": "vin",
		"body": [
			"for(auto &${1:x} : $2) cin >> ${1:x};"
		]
	},
	"Sort": {
		"prefix": "s",
		"body": [
			"sort(all($1));"
		]
	},
	"Reverse": {
		"prefix": "rv",
		"body": [
			"reverse(all($1));"
		]
	},
	"Binary Search": {
		"prefix": "bs",
		"body": [
			"int $1 = 0, $2 = $3 - 1;",
			"while($1 <= $2){",
			"    int $4 = ($1 + $2) / 2;",
			"    if($5){",
			"        $2 = $4 - 1;",
			"    } else {",
			"        $1 = $4 + 1;",
			"    }",
			"}"
		]
	},
	"Set": {
		"prefix": "st",
		"body": [
			"set<$1> $2;"
		]
	},
	"Map": {
		"prefix": "mp",
		"body": [
			"map<$1,$2> $3;"
		]
	},
	"Priority Queue": {
		"prefix": "pq",
		"body": [
			"priority_queue<$1> $2;"
		]
	},
	"Min Element": {
		"prefix": "minv",
		"body": [
			"*min_element($1.begin(), $1.end())"
		]
	},
	"Max Element": {
		"prefix": "maxv",
		"body": [
			"*max_element($1.begin(), $1.end())"
		]
	},
	"Min Max Element": {
		"prefix": "mmv",
		"body": [
			"auto [$1,$2] = minmax_element($3.begin(), $3.end());"
		]
	},
	"Set Min": {
		"prefix": "mins",
		"body": [
			"*$1.begin()"
		]
	},
	"Set Max": {
		"prefix": "maxs",
		"body": [
			"*$1.rbegin()"
		]
	},
	"Map Min Key": {
		"prefix": "minmk",
		"body": [
			"$1.begin()->first"
		]
	},
	"Map Max Key": {
		"prefix": "maxmk",
		"body": [
			"$1.rbegin()->first"
		]
	},
	"Map Min Value": {
		"prefix": "minmv",
		"body": [
			"$1.begin()->second"
		]
	},
	"Map Max Value": {
		"prefix": "maxmv",
		"body": [
			"$1.rbegin()->second"
		]
	}
}
